# Backend API URL (required for production)
VITE_API_URL=http://localhost:5000/api



# Mapbox access token (required for Submit Report location/geocoding)
# Get a token at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_ACCESS_TOKEN=

# Google Maps API key (required for Places autocomplete on Submit Report map/search)
VITE_GOOGLE_MAPS_API_KEY=
