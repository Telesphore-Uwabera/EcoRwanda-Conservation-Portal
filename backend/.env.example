###############################################################################
# EcoRwanda Backend (.env example)
# Copy to backend/.env and fill values for local dev.
# Never commit backend/.env.
###############################################################################

# App environment
NODE_ENV=development
PORT=5000

# Database (MongoDB)
MONGODB_URI=

# Auth
JWT_SECRET=

# Frontend URL (used for password reset links)
FRONTEND_URL=http://localhost:5173

# Email (Brevo REST API)
# Create an API key in Brevo -> SMTP & API
BREVO_API_KEY=
# Sender identity must be a verified sender/domain in Brevo
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=EcoRwanda Conservation Portal

# Default administrator seeding (optional)
DEFAULT_ADMIN_EMAIL=info.teletech.rw@gmail.com
DEFAULT_ADMIN_PASSWORD=ADMIN123

